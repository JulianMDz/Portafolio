---
import { ModeToggle } from './ModeToggle';
---

<nav class="nav">
	<a href="/" class="nav__logo">MDz</a>

	<div class="nav-links">
		<a href="#hero">home</a>
		<a href="#projects">projects</a>
		<a href="#about">About me</a>
	</div>

	<div class="nav-actions">
		<ModeToggle client:load />
	</div>
</nav>

<style>
	nav {
		position: fixed;
		width: 100%;
		/* Sit above the GradualBlur page overlays (zIndex 1100) so the nav
		   itself stays sharp instead of being blurred along with the content
		   scrolling underneath it. */
		z-index: 1200;
		display: flex;
		justify-content: space-between;
		padding: 2rem 3rem;
	}

	.nav__logo {
		/* Same glass-pill treatment and height as .nav-links / the theme
		   toggle button (2.25rem = Button's icon size), so the three nav
		   chips read as one coherent set instead of bare text next to pills. */
		display: inline-flex;
		align-items: center;
		height: 2.25rem;
		padding: 0 1.1rem;
		border-radius: var(--radius);
		background: color-mix(in oklch, var(--foreground) 6%, transparent);
		border: 1px solid color-mix(in oklch, var(--foreground) 12%, transparent);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		font-family: var(--font-sans);
		font-size: 1rem;
		color: var(--foreground);
		text-decoration: none;
		transition: color 0.2s ease, background-color 0.2s ease, border-color 0.2s ease;
	}

	.nav__logo:hover {
		color: var(--primary);
		background: color-mix(in oklch, var(--primary) 14%, transparent);
		border-color: color-mix(in oklch, var(--primary) 35%, transparent);
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		padding: 0.6rem 1.5rem;
		border-radius: var(--radius);
		background: color-mix(in oklch, var(--foreground) 6%, transparent);
		border: 1px solid color-mix(in oklch, var(--foreground) 12%, transparent);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
	}

	.nav-links a {
		text-decoration: none;
		color: var(--foreground);
		font-family: var(--font-sans);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		transition: color 0.2s ease;
	}

	.nav-links a:hover {
		color: var(--primary);
	}

	.nav-actions {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	/* Mobile: collapse into a single bottom tab bar instead of a top strip —
	   the logo is dropped (its "home" link already lives in .nav-links) and
	   the links + theme toggle are grouped together instead of being spread
	   to the container's edges. */
	@media (max-width: 480px) {
		nav {
			top: auto;
			bottom: 0;
			justify-content: center;
			gap: 0.75rem;
			padding: 0.85rem 1rem calc(1.75rem + env(safe-area-inset-bottom));
		}

		.nav__logo {
			display: none;
		}

		.nav-links {
			gap: 1.1rem;
			padding: 0.5rem 1.1rem;
		}

		.nav-links a {
			font-size: 0.75rem;
		}
	}
</style>
