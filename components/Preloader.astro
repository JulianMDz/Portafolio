---
---

<div id="preloader" class="preloader">
	<div class="preloader-header">
		<h1>JulianMDz</h1>
		<div class="preloader-counter">
			<p>000</p>
		</div>
	</div>
</div>

<style>
	html.is-loading,
	html.is-loading body {
		height: 100%;
		overflow: hidden;
	}

	.preloader {
		position: fixed;
		inset: 0;
		z-index: 9999;
		overflow: hidden;
		background: var(--background);
		clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%);
		will-change: clip-path;
	}

	.preloader-header {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		text-align: center;
	}

	.preloader-header h1 {
		margin: 0;
		font-family: var(--font-sans);
		font-size: clamp(2rem, 10vw, 16rem);
		font-weight: bold;
		color: var(--foreground);
	}

	.preloader-counter {
		position: absolute;
		top: -1.5rem;
		left: calc(100% - 1.5rem);
		overflow: hidden;
	}

	.preloader-counter p {
		margin: 0;
		font-family: var(--font-mono);
		font-size: clamp(1rem, 1.5vw, 2rem);
		color: var(--foreground);
		opacity: 0;
		will-change: opacity;
	}
</style>

<script>
	import { gsap, SplitText, registerEases, prefersReducedMotion } from '../lib/gsap';

	registerEases();

	const preloader = document.getElementById('preloader');
	const title = document.querySelector<HTMLHeadingElement>('.preloader-header h1');
	const counter = document.querySelector<HTMLParagraphElement>('.preloader-counter p');

	if (preloader && title && counter) {
		document.documentElement.classList.add('is-loading');

		const speed = prefersReducedMotion() ? 0.25 : 1;
		const split = SplitText.create(title, { type: 'chars', mask: 'chars' });
		const counterProxy = { value: 0 };

		const tl = gsap.timeline({
			defaults: { ease: 'hop' },
			onComplete: () => {
				(window as any).__preloaderDone = true;
				window.dispatchEvent(new CustomEvent('preloader:complete'));
				document.documentElement.classList.remove('is-loading');
				preloader.remove();
			}
		});

		tl.set(split.chars, { yPercent: 120 })
			.to(split.chars, {
				yPercent: 0,
				duration: 1 * speed,
				stagger: 0.04 * speed
			})
			.to(
				counter,
				{
					opacity: 1,
					duration: 0.3 * speed
				},
				'<'
			)
			.to(
				counterProxy,
				{
					value: 100,
					duration: 1.3 * speed,
					ease: 'power2.inOut',
					onUpdate: () => {
						counter.textContent = String(Math.round(counterProxy.value)).padStart(3, '0');
					}
				},
				'<'
			)
			.to(
				split.chars,
				{
					yPercent: -120,
					duration: 0.8 * speed,
					stagger: 0.03 * speed,
					ease: 'hop2'
				},
				'>0.2'
			)
			.to(
				counter,
				{
					opacity: 0,
					duration: 0.4 * speed
				},
				'<'
			)
			.to(
				preloader,
				{
					clipPath: 'polygon(0% 0%, 100% 0%, 100% 0%, 0% 0%)',
					duration: 1 * speed,
					ease: 'hop'
				},
				'-=0.2'
			);
	}
</script>
