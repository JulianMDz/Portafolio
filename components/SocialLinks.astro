---

<ul class="social-links">
	{socials.map((social) => (
		<li>
			<a href={social.href} class="social-links__item" aria-label={social.name} target="_blank" rel="noopener noreferrer">
				<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
					<path d={social.path} />
				</svg>
			</a>
		</li>
	))}
</ul>

<style>
	.social-links {
		display: flex;
		gap: 0.75rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.social-links__item {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.75rem;
		height: 2.75rem;
		border-radius: 999px;
		color: var(--foreground);
		background: color-mix(in oklch, var(--foreground) 6%, transparent);
		border: 1px solid color-mix(in oklch, var(--foreground) 12%, transparent);
		transition: background-color 0.2s ease, transform 0.2s ease;
	}

	.social-links__item:hover {
		background: color-mix(in oklch, var(--foreground) 14%, transparent);
		transform: translateY(-2px);
	}
</style>
