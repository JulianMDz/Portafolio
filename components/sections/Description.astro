---
import ScrambledText from '../ScrambledText';
import SocialLinks from '../SocialLinks.astro';
---

<!-- PANTALLA 3 — SECTION DESCRIPTION -->
<section id="description" class="section description">
	<h2 class="description__title">JulianMDz</h2>

	<div class="description__bio">
		<ScrambledText client:visible radius={80} duration={1} speed={0.5} scrambleChars=".:">
			Developer and 3D artist. I build web experiences with attention to detail, from interfaces to shaders, also experiment with 3D technologies.
		</ScrambledText>
	</div>

	<SocialLinks />
</section>

<style>
	.description {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 1.5rem;
		min-height: 100vh;
		padding: 4rem 1.5rem;
		text-align: center;
	}

	.description__title {
		margin: 0;
		font-family: var(--font-sans);
		font-size: clamp(2rem, 6vw, 6rem);
		font-weight: bold;
		color: var(--foreground);
	}

	.description__bio {
		max-width: 43rem;
		font-size: clamp(1rem, 1.6vw, 1.25rem);
		line-height: 1.6;
		color: var(--foreground);
		opacity: 0.85;
		will-change: transform, opacity;
	}

	/* Forcing a full viewport height per section left huge empty gaps on
	   mobile, where the content itself is much shorter than 100vh — let the
	   section hug its content instead. */
	@media (max-width: 768px) {
		.description {
			min-height: auto;
			padding: 5rem 1.5rem;
		}
	}
</style>

<script>
	import { gsap, splitChars, scrollCharsInOut, registerEases } from '../../lib/gsap';

	registerEases();

	const title = document.querySelector<HTMLHeadingElement>('.description__title');
	const bio = document.querySelector<HTMLDivElement>('.description__bio');
	const socials = document.querySelector<HTMLUListElement>('.social-links');

	if (title) {
		// Same rising letter-mask language as the Preloader/Hero nickname,
		// just driven by this section's own scroll position: rises in, then
		// rises back out as the page moves on to Projects.
		const split = splitChars(title);
		scrollCharsInOut(split.chars, '#description');
	}

	if (bio && socials) {
		gsap.set([bio, socials], { y: 24, opacity: 0 });

		gsap.to([bio, socials], {
			y: 0,
			opacity: 1,
			duration: 0.8,
			stagger: 0.15,
			ease: 'hop',
			scrollTrigger: {
				trigger: '#description',
				start: 'top 45%',
				toggleActions: 'play none none reverse'
			}
		});
	}
</script>
