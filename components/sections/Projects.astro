---
import TiltedCard from '../TiltedCard';
import { projects } from '../../lib/projects';
---

<!-- PANTALLA 4 — SECTION PROJECTS -->
<section id="projects" class="section projects">
	<div class="section-tag">
		<h1>Projects</h1>
	</div>

	<div class="projects__tabs" role="tablist">
		<button type="button" class="projects__tab is-active" role="tab" data-category="DEV" aria-selected="true">DEV</button>
		<button type="button" class="projects__tab" role="tab" data-category="3D" aria-selected="false">3D</button>
	</div>

	<div class="projects__content">
		<div class="projects__list-viewport">
			<ul class="projects__list">
				{projects.map((project, i) => (
					<li>
						<a
							href={`/projects/${project.slug}`}
							class="projects__name"
							class:list={[{ 'is-active': i === 0 }]}
							data-index={i}
							data-category={project.category}
							data-slug={project.slug}
						>
							{project.name}
						</a>
					</li>
				))}
			</ul>
		</div>

		<div class="projects__cards">
			{projects.map((project, i) => (
				<div class="projects__card" class:list={[{ 'is-active': i === 0 }]} data-index={i} data-category={project.category}>
					<a href={`/projects/${project.slug}`} class="projects__card-link" aria-label={`View ${project.name} project`}>
						<TiltedCard
							client:visible
							imageSrc={project.images[0]}
							altText={project.name}
							captionText={project.name}
							containerHeight="320px"
							containerWidth="460px"
							imageHeight="320px"
							imageWidth="460px"
							rotateAmplitude={22}
							scaleOnHover={1.05}
							showMobileWarning={false}
							showTooltip
						/>
					</a>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.projects {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.5rem;
		min-height: 100vh;
		padding: 4rem 1.5rem;
	}

	.projects__tabs {
		display: inline-flex;
		gap: 0.25rem;
		padding: 0.35rem;
		border-radius: var(--radius);
		background: color-mix(in oklch, var(--foreground) 4%, transparent);
		border: 1px solid color-mix(in oklch, var(--foreground) 10%, transparent);
	}

	.section-tag h1 {
		margin: 0;
		font-family: var(--font-sans);
		font-size: clamp(2rem, 6vw, 6rem);
		font-weight: bold;
		text-transform: uppercase;
		color: var(--foreground);
	}

	.projects__tab {
		padding: 0.5rem 1.5rem;
		border: none;
		border-radius: calc(var(--radius) - 0.2rem);
		background: transparent;
		color: var(--foreground);
		font-family: var(--font-sans);
		font-size: 0.9rem;
		letter-spacing: 0.05em;
		cursor: pointer;
		opacity: 0.5;
		transition: background-color 0.2s ease, opacity 0.2s ease;
	}

	.projects__tab:hover {
		opacity: 0.8;
	}

	.projects__tab.is-active {
		opacity: 1;
		color: var(--primary);
		background: color-mix(in oklch, var(--primary) 14%, transparent);
	}

	.projects__content {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		align-items: center;
		gap: 2rem;
		width: 100%;
		max-width: 64rem;
		padding: 2rem;
		border-radius: 1.5rem;
		background: color-mix(in oklch, var(--foreground) 3%, transparent);
	}

	.projects__list-viewport {
		height: 24rem;
		overflow: hidden;
		mask-image: linear-gradient(to bottom, transparent, black 30%, black 70%, transparent);
		touch-action: none;
	}

	.projects__list {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		will-change: transform;
	}

	.projects__name {
		border: none;
		background: transparent;
		color: var(--foreground);
		font-family: var(--font-sans);
		font-size: clamp(1.1rem, 2vw, 1.5rem);
		text-align: left;
		cursor: pointer;
		transition: color 0.2s ease;
	}

	.projects__name.is-active {
		color: var(--primary);
	}

	.projects__cards {
		position: relative;
		width: 480px;
		height: 320px;
	}

	.projects__card {
		display: none;
	}

	.projects__card.is-active {
		display: block;
	}

	.projects__card-link {
		display: block;
		text-decoration: none;
	}

	/* Mobile: no room (or need) for the image carousel — just a plain,
	   fully visible list of names that link straight to each project's
	   detail page, instead of the wheel-driven single-item viewport. */
	@media (max-width: 480px) {
		.projects__content {
			grid-template-columns: 1fr;
		}

		.projects__list-viewport {
			height: auto;
			overflow: visible;
			mask-image: none;
			touch-action: auto;
		}

		.projects__name {
			display: block;
			padding: 0.5rem 0;
			text-decoration: none;
		}

		.projects__cards {
			display: none;
		}
	}

	/* Forcing a full viewport height per section left huge empty gaps on
	   mobile, where the content itself is much shorter than 100vh — let the
	   section hug its content instead. */
	@media (max-width: 768px) {
		.projects {
			min-height: auto;
			padding: 5rem 1.5rem;
		}
	}
</style>

<script>
	import { gsap, registerEases } from '../../lib/gsap';

	registerEases();

	// Entrance: title, tabs and the list/card panel rise and fade in together
	// as the section scrolls into view, same "hop" language as Description.
	const sectionTag = document.querySelector('.projects .section-tag');
	const tabsWrap = document.querySelector('.projects__tabs');
	const content = document.querySelector('.projects__content');

	if (sectionTag && tabsWrap && content) {
		gsap.set([sectionTag, tabsWrap, content], { y: 32, opacity: 0 });
		gsap.to([sectionTag, tabsWrap, content], {
			y: 0,
			opacity: 1,
			duration: 0.8,
			stagger: 0.12,
			ease: 'hop',
			scrollTrigger: {
				trigger: '#projects',
				start: 'top 70%',
				toggleActions: 'play none none reverse'
			}
		});
	}

	const tabs = document.querySelectorAll<HTMLButtonElement>('.projects__tab');
	const cards = document.querySelectorAll<HTMLDivElement>('.projects__card');
	const viewport = document.querySelector<HTMLDivElement>('.projects__list-viewport');
	const list = document.querySelector<HTMLUListElement>('.projects__list');
	const allItems = Array.from(document.querySelectorAll<HTMLLIElement>('.projects__list li'));

	function clamp(value: number, min: number, max: number) {
		return Math.min(max, Math.max(min, value));
	}

	function isMobileLayout() {
		return window.matchMedia('(max-width: 480px)').matches;
	}

	if (viewport && list && allItems.length) {
		// The natural browser wheel/scroll-snap combo let a single wheel tick
		// (or a fast trackpad flick) jump several projects at once, which felt
		// abrupt. Instead of native scrolling, the wheel/touch handlers below
		// only nudge a *virtual* continuous index, and GSAP eases the list
		// toward it — so every project change is a controlled, damped step.
		let visibleItems = allItems;
		const state = { index: 0 };
		let target = 0;

		function itemCenterOffset(i: number) {
			const item = visibleItems[i];
			return item.offsetTop + item.offsetHeight / 2;
		}

		function render() {
			if (!visibleItems.length) return;

			// Mobile has no image carousel to sync against — it's a plain
			// list of link names, so skip the positioning transform and
			// leave every name at its natural style (in case of a resize
			// down from desktop, where inline styles may already be set).
			if (isMobileLayout()) {
				gsap.set(list, { y: 0 });
				allItems.forEach((li) => {
					const name = li.querySelector<HTMLAnchorElement>('.projects__name');
					if (!name) return;
					name.style.opacity = '';
					name.style.fontWeight = '';
				});
				return;
			}

			const idx = clamp(state.index, 0, visibleItems.length - 1);
			const lower = Math.floor(idx);
			const upper = Math.min(visibleItems.length - 1, lower + 1);
			const frac = idx - lower;
			const centerOffset = itemCenterOffset(lower) + (itemCenterOffset(upper) - itemCenterOffset(lower)) * frac;

			gsap.set(list, { y: (viewport?.clientHeight ?? 0) / 2 - centerOffset });

			const nearest = Math.round(idx);
			allItems.forEach((li) => {
				const name = li.querySelector<HTMLAnchorElement>('.projects__name');
				if (name && !visibleItems.includes(li)) name.classList.remove('is-active');
			});
			visibleItems.forEach((li, i) => {
				const name = li.querySelector<HTMLAnchorElement>('.projects__name');
				if (!name) return;
				const dist = Math.abs(i - idx);
				name.style.opacity = String(clamp(1 - dist * 0.35, 0.25, 1));
				name.style.fontWeight = String(Math.round(400 + clamp(1 - dist, 0, 1) * 300));
				name.classList.toggle('is-active', i === nearest);
			});

			// Real-time: whichever card is nearest is shown instantly (no
			// animation here) so the image always tracks the list as it
			// scrolls — the pop-in only plays once scrolling actually settles,
			// see goTo()'s onComplete below.
			const activeIndex = visibleItems[nearest]?.querySelector<HTMLAnchorElement>('.projects__name')?.dataset
				.index;
			cards.forEach((card) => card.classList.toggle('is-active', card.dataset.index === activeIndex));
		}

		function popActiveCard() {
			const activeCard = Array.from(cards).find((card) => card.classList.contains('is-active'));
			if (!activeCard) return;
			gsap.fromTo(
				activeCard,
				{ opacity: 0, scale: 0.92, y: 14 },
				{ opacity: 1, scale: 1, y: 0, duration: 0.5, ease: 'hop', overwrite: true }
			);
		}

		function goTo(newTarget: number, duration = 0.7) {
			target = clamp(newTarget, 0, visibleItems.length - 1);
			gsap.to(state, {
				index: target,
				duration,
				ease: 'power3.out',
				overwrite: true,
				onUpdate: render,
				// A fast multi-item scroll overwrites this tween repeatedly, so
				// onComplete only ever fires for the one that actually finishes
				// — i.e. once the user has settled on a project, not per frame.
				onComplete: popActiveCard
			});
		}

		viewport.addEventListener(
			'wheel',
			(e) => {
				if (isMobileLayout()) return; // let the page scroll normally over the plain link list
				e.preventDefault();
				// Damped: a full wheel tick (~100px) only moves ~1/3 of a project,
				// so scrolling through the list feels gradual instead of instant.
				goTo(target + e.deltaY * 0.0035, 0.6);
			},
			{ passive: false }
		);

		let touchStartY = 0;
		viewport.addEventListener(
			'touchstart',
			(e) => {
				if (isMobileLayout()) return; // no carousel to drag — let native touch scrolling handle the page
				touchStartY = e.touches[0].clientY;
			},
			{ passive: true }
		);
		viewport.addEventListener(
			'touchmove',
			(e) => {
				if (isMobileLayout()) return;
				const dy = touchStartY - e.touches[0].clientY;
				touchStartY = e.touches[0].clientY;
				goTo(target + dy * 0.02, 0.3);
			},
			{ passive: true }
		);

		allItems.forEach((li) => {
			li.querySelector<HTMLAnchorElement>('.projects__name')?.addEventListener('click', (e) => {
				// On mobile there's no card preview to select — the name is a
				// plain link, so let it navigate to the project page normally.
				if (isMobileLayout()) return;
				e.preventDefault();
				const position = visibleItems.indexOf(li);
				if (position !== -1) goTo(position);
			});
		});

		function filterByCategory(category: string, keepIndex = 0) {
			visibleItems = allItems.filter((li) => {
				const matches = li.querySelector<HTMLAnchorElement>('.projects__name')?.dataset.category === category;
				li.style.display = matches ? '' : 'none';
				return matches;
			});
			target = keepIndex;
			state.index = keepIndex;
			render();
		}

		function activateCategory(category: string, keepIndex = 0) {
			tabs.forEach((t) => {
				const isMatch = t.dataset.category === category;
				t.classList.toggle('is-active', isMatch);
				t.setAttribute('aria-selected', String(isMatch));
			});
			filterByCategory(category, keepIndex);
		}

		tabs.forEach((tab) => {
			tab.addEventListener('click', () => {
				if (tab.dataset.category) activateCategory(tab.dataset.category);
			});
		});

		// If arriving from a project's detail page (Back link carries ?project=slug),
		// land on that project's category with it already selected instead of
		// always resetting to the first DEV project.
		const targetSlug = new URLSearchParams(window.location.search).get('project');
		const targetItem = targetSlug
			? allItems.find((li) => li.querySelector<HTMLAnchorElement>('.projects__name')?.dataset.slug === targetSlug)
			: undefined;
		const targetButton = targetItem?.querySelector<HTMLAnchorElement>('.projects__name');

		// Wait a frame so layout (fonts, TiltedCard images) has settled before
		// measuring offsets for the first render.
		requestAnimationFrame(() => {
			if (targetButton?.dataset.category) {
				const categoryItems = allItems.filter(
					(li) =>
						li.querySelector<HTMLAnchorElement>('.projects__name')?.dataset.category === targetButton.dataset.category
				);
				const targetIndex = categoryItems.indexOf(targetItem!);
				activateCategory(targetButton.dataset.category, targetIndex === -1 ? 0 : targetIndex);
				history.replaceState(null, '', window.location.pathname + window.location.hash);
			} else {
				// A plain visit (no deep link) never actually filtered by the
				// DEV tab that's already marked active in the static HTML —
				// render() alone doesn't hide the non-matching items, so every
				// project showed until a tab was clicked. Apply that filter now.
				activateCategory('DEV');
			}
		});
		window.addEventListener('resize', render);
	}
</script>
