---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectGallery from '../../../components/ProjectGallery';
import ScrambledText from '../../../components/ScrambledText';
import { projects } from '../../../lib/projects';

export function getStaticPaths() {
	return projects.map((project) => ({
		params: { slug: project.slug },
		props: { project }
	}));
}

const { project } = Astro.props;
---

<BaseLayout title={`${project.name} — Portafolio`} showNav={false} showFooter={false}>
	<section class="project-detail">
		<a href={`/?project=${project.slug}#projects`} class="project-detail__back">&#8598; Back</a>

		<div class="project-detail__layout">
			<div class="project-detail__info">
				<h1 class="project-detail__title">
					<span class="project-detail__name">{project.name}</span>
					<span class="project-detail__year">{project.year}</span>
				</h1>

				<div class="project-detail__description">
					<ScrambledText client:visible radius={80} duration={1} speed={0.5} scrambleChars=".:">
						{project.description}
					</ScrambledText>
				</div>

				<ul class="project-detail__techs">
					{project.techs.map((tech) => (
						<li>{tech.toUpperCase()}</li>
					))}
				</ul>
			</div>

			<ProjectGallery client:load name={project.name} images={project.images} url={project.url} />
		</div>
	</section>
</BaseLayout>

<style>
	.project-detail {
		display: flex;
		flex-direction: column;
		gap: 3rem;
		min-height: 100vh;
		padding: 6rem 3rem 4rem;
	}

	.project-detail__back {
		align-self: flex-start;
		font-family: var(--font-sans);
		font-size: 0.85rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--foreground);
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.project-detail__back:hover {
		color: var(--primary);
		text-decoration: underline;
	}

	.project-detail__layout {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		align-items: center;
		gap: 3rem;
		flex: 1;
	}

	.project-detail__title {
		display: flex;
		align-items: baseline;
		gap: 0.75rem;
		margin: 0 0 1.5rem;
		font-family: var(--font-sans);
		font-size: clamp(2.5rem, 6vw, 5rem);
		font-weight: 800;
		color: var(--foreground);
	}

	.project-detail__year {
		font-size: 1rem;
		font-weight: 400;
		opacity: 0.6;
	}

	.project-detail__description {
		max-width: 28rem;
		margin: 0 0 1.5rem;
		font-family: var(--font-body);
		font-size: clamp(1rem, 1.4vw, 1.15rem);
		font-weight: 400;
		line-height: 1.6;
		color: var(--foreground);
		opacity: 0.85;
	}

	.project-detail__techs {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.project-detail__techs li {
		padding: 0.4rem 0.85rem;
		border-radius: calc(var(--radius) - 0.2rem);
		border: 1px solid color-mix(in oklch, var(--primary) 30%, transparent);
		background: color-mix(in oklch, var(--primary) 8%, transparent);
		font-family: var(--font-mono);
		font-size: 0.7rem;
		letter-spacing: 0.05em;
		color: var(--primary);
	}

	/* Lives here (not in the is:global block below) because Astro scopes
	   this file's own selectors with a data-astro-cid attribute, raising
	   their specificity — an unscoped override in the global block was
	   losing to the desktop rule above regardless of media query, leaving
	   the grid stuck at 2 columns and squeezing the text column to ~0px. */
	@media (max-width: 834px) {
		.project-detail__layout {
			grid-template-columns: 1fr;
		}
	}
</style>

<style is:global>
	.project-detail__gallery {
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}

	.project-detail__thumbs {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		max-height: 480px;
		overflow-y: auto;
		padding: 0.25rem;
		scroll-behavior: smooth;
		scrollbar-width: none;
	}

	.project-detail__thumbs::-webkit-scrollbar {
		display: none;
	}

	.project-detail__thumb {
		flex-shrink: 0;
		width: 96px;
		height: 64px;
		padding: 0;
		border-radius: 0.5rem;
		border: 2px solid transparent;
		overflow: hidden;
		cursor: pointer;
		opacity: 0.5;
		transition: opacity 0.2s ease, border-color 0.2s ease;
	}

	.project-detail__thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.project-detail__thumb:hover {
		opacity: 0.8;
	}

	.project-detail__thumb.is-active {
		opacity: 1;
		border-color: var(--primary);
	}

	.project-detail__main-link {
		position: relative;
		display: block;
		width: fit-content;
	}

	.project-detail__main-badge {
		position: absolute;
		top: 0.75rem;
		right: 0.75rem;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.25rem;
		height: 2.25rem;
		border-radius: var(--radius);
		border: 1px solid color-mix(in oklch, var(--foreground) 12%, transparent);
		background: color-mix(in oklch, var(--background) 85%, transparent);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		color: var(--foreground);
		font-size: 1.1rem;
		opacity: 0;
		transform: translateY(-4px);
		transition: opacity 0.2s ease, transform 0.2s ease, color 0.2s ease, border-color 0.2s ease;
		pointer-events: none;
	}

	.project-detail__main-link:hover .project-detail__main-badge {
		opacity: 1;
		transform: translateY(0);
		color: var(--primary);
		border-color: color-mix(in oklch, var(--primary) 35%, transparent);
	}

	@media (max-width: 834px) {
		.project-detail__gallery {
			flex-direction: column-reverse;
		}

		.project-detail__thumbs {
			flex-direction: row;
			max-height: none;
			max-width: 100%;
		}
	}
</style>

<script>
	import { gsap, splitChars, registerEases, prefersReducedMotion } from '../../../lib/gsap';

	registerEases();

	// Page-load entrance: back link and title lead, description/techs/gallery
	// follow in a light stagger — same "hop" language as the rest of the site,
	// just triggered on load instead of scroll since this page opens straight
	// into its content.
	const speed = prefersReducedMotion() ? 0.25 : 1;
	const back = document.querySelector<HTMLAnchorElement>('.project-detail__back');
	const title = document.querySelector<HTMLSpanElement>('.project-detail__name');
	const description = document.querySelector<HTMLDivElement>('.project-detail__description');
	const techs = document.querySelector<HTMLUListElement>('.project-detail__techs');
	const gallery = document.querySelector<HTMLDivElement>('.project-detail__gallery');

	const tl = gsap.timeline({ defaults: { ease: 'hop' } });

	if (back) {
		gsap.set(back, { y: -12, opacity: 0 });
		tl.to(back, { y: 0, opacity: 1, duration: 0.5 * speed }, 0);
	}

	if (title) {
		const split = splitChars(title);
		gsap.set(split.chars, { yPercent: 120 });
		tl.to(split.chars, { yPercent: 0, duration: 0.8 * speed, stagger: 0.02 }, 0.1);
	}

	if (description) {
		gsap.set(description, { y: 20, opacity: 0 });
		tl.to(description, { y: 0, opacity: 0.85, duration: 0.6 * speed }, 0.35);
	}

	if (techs?.children.length) {
		gsap.set(techs.children, { y: 12, opacity: 0 });
		tl.to(techs.children, { y: 0, opacity: 1, duration: 0.4 * speed, stagger: 0.05 }, 0.5);
	}

	if (gallery) {
		gsap.set(gallery, { y: 20, opacity: 0 });
		tl.to(gallery, { y: 0, opacity: 1, duration: 0.7 * speed }, 0.3);
	}
</script>
